# Cổng vào chính của trang web
@app.route('/')
def index():
    # Trả về giao diện và truyền kèm trạng thái thiết bị
    return render_template_string(HTML_TEMPLATE, status=device_status)

# Đường dẫn xử lý khi người dùng nhấn nút Bật/Tắt
@app.route('/toggle')
def toggle_led():
    # Thay đổi trạng thái LED qua lại
    if device_status["led"] == "TẮT":
        device_status["led"] = "BẬT"
        # (Tại đây bạn có thể code thêm lệnh bật GPIO của Raspberry Pi nếu có phần cứng thật)
        print("[HỆ THỐNG] Đã gửi lệnh BẬT ĐÈN tới phần cứng.")
    else:
        device_status["led"] = "TẮT"
        # (Tại đây bạn có thể code thêm lệnh tắt GPIO của Raspberry Pi)
        print("[HỆ THỐNG] Đã gửi lệnh TẮT ĐÈN tới phần cứng.")
        
    return render_template_string(HTML_TEMPLATE, status=device_status)

# API bổ sung (nếu bài học yêu cầu trả về dữ liệu JSON cho ứng dụng mobile/ajax)
@app.route('/api/status', methods=['GET'])
def get_status():
    return jsonify(device_status)

if __name__ == '__main__':
    print("[KHỞI CHẠY] Web Server đang bắt đầu chạy...")
    # host='0.0.0.0' cho phép tất cả các thiết bị cùng mạng Wi-Fi truy cập vào (ví dụ dùng điện thoại vào web)
    # port=5000 là cổng mặc định của Flask
    app.run(host='0.0.0.0', port=5000, debug=True)
