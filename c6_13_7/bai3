import sys
from flask import Flask, render_template_string, request, jsonify

app = Flask(__name__)

# Giả lập trạng thái của thiết bị phần cứng (Ví dụ trên Raspberry Pi)
device_status = {
    "led": "TẮT",
    "temperature": 27.5,
    "humidity": 65.0
}

# Giao diện HTML/CSS được viết trực tiếp dưới dạng String để dễ quản lý trong 1 file
HTML_TEMPLATE = """
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Samsung Innovation Campus - IoT Web Server</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 20px;
            text-align: center;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        h1 { color: #0077b6; margin-bottom: 10px; }
        h3 { color: #555; font-weight: 400; }
        .card {
            background: #e0f7fa;
            padding: 15px;
            border-radius: 10px;
            margin: 20px 0;
            font-size: 18px;
        }
        .btn {
            background-color: #009688;
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 18px;
            border-radius: 25px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }
        .btn:hover { background-color: #00796b; }
        .btn-off { background-color: #d32f2f; }
        .btn-off:hover { background-color: #c2185b; }
        .status-on { color: #2e7d32; font-weight: bold; }
        .status-off { color: #c62828; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <h1>SAMSUNG INNOVATION CAMPUS</h1>
    <h3>Bài 3: Lập trình Điều khiển Thiết bị qua Web Server</h3>
    <hr>
    
    <!-- Hiển thị dữ liệu cảm biến cảm biến -->
    <div class="card">
        <p>🌡️ <b>Nhiệt độ hiện tại:</b> {{ status.temperature }} °C</p>
        <p>💧 <b>Độ ẩm hiện tại:</b> {{ status.humidity }} %</p>
    </div>

    <!-- Hiển thị trạng thái Đèn LED -->
    <div class="card">
        <p>Trạng thái Đèn: 
            <span class="{% if status.led == 'BẬT' %}status-on{% else %}status-off{% endif %}">
                {{ status.led }}
            </span>
        </p>
        
        <!-- Nút nhấn đổi trạng thái -->
        <a href="/toggle" class="btn {% if status.led == 'BẬT' %}btn-off{% endif %}">
            {% if status.led == 'BẬT' %} Tắt Đèn {% else %} Bật Đèn {% endif %}
        </a>
    </div>
    
    <p style="font-size: 12px; color: #888;">© 2026 Toàn bộ mã nguồn bản quyền thực hành SIC</p>
